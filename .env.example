# 火山引擎豆包同声传译 2.0 密钥
# 控制台：https://console.volcengine.com/speech/app
DOUBAO_APP_KEY=
DOUBAO_ACCESS_KEY=
DOUBAO_RESOURCE_ID=volc.service_type.10053

# 可选覆盖（留空则用默认）
# SOURCE_LANG=zh
# TARGET_LANG=en
# MODE=s2s
# INPUT_DEVICE=
# OUTPUT_DEVICE=CABLE Input
# LOG_LEVEL=INFO
# DENOISE=0  # 服务端降噪：0=关（默认，保留音色细节供克隆）/ 1=开
